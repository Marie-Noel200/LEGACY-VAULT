# ── SERVER ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL=https://your-app-url.up.railway.app

# ── DATABASE ───────────────────────────────────────────────────
# For Railway: copy values from your MySQL service variables
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=legacy_vault

# ── SECURITY ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS
# Must be exactly 32 characters
AES_SECRET=CHANGE_THIS_32_CHAR_AES_KEY_HERE
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET

# ── EMAIL (nodemailer) ─────────────────────────────────────────
# Gmail: use an App Password (not your real password)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password
